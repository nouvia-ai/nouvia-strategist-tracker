rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: single-user gate (INT-001 ADR-P02) ──────────────────────────
    function isBen() {
      return request.auth != null
          && request.auth.token.email == 'benmelchionno@nouvia.ai';
    }

    // ── Helper: authenticated user ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Portal: user roles (read own, Ben writes all) ────────────────────────
    match /portal_users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated();
    }

    // ── Portal: client-facing collections (authenticated users can read/write) ─
    match /portal_projects/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /portal_activity/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /portal_documents/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /portal_requests/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── Existing: per-user data store (getData / setData helpers) ───────────
    match /users/{userId}/{document=**} {
      allow read, write: if isBen();
    }

    // ── INT-001 WS1: IP Library ─────────────────────────────────────────────
    match /ip_library/{docId} {
      allow read, write: if isBen();
    }

    // ── INT-001 WS2: Dashboard collections ─────────────────────────────────
    match /okrs/{docId} {
      allow read, write: if isBen();
    }

    match /mrr_entries/{docId} {
      allow read, write: if isBen();
    }

    match /priority_queue/{docId} {
      allow read, write: if isBen();
    }

    match /tracker_events/{docId} {
      allow read, write: if isBen();
    }

    // ── INT-002 CEO Cockpit collections ─────────────────────────────────────
    match /goals/{docId} {
      allow read, write: if isBen();
    }

    match /client_backlog/{docId} {
      allow read, write: if isBen();
    }

    match /weekly_todos/{docId} {
      allow read, write: if isBen();
    }

    match /forecast_cache/{docId} {
      allow read, write: if isBen();
    }

    match /experiments/{docId} {
      allow read, write: if isBen();
    }

    match /trends/{docId} {
      allow read, write: if isBen();
    }

    match /decisions/{docId} {
      allow read, write: if isBen();
    }

    // ── IVC AI Cockpit collections (authenticated users can read/write) ────
    match /ivc_goals/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /ivc_issues/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /ivc_pillars/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /ivc_ideas/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /ivc_backlog/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /ivc_audit_log/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ── NIP Architecture status ───────────────────────────────────────────
    match /nip_architecture/{doc} {
      allow read, write: if isAuthenticated();
    }

    // ── Master Backlog collections ────────────────────────────────────────
    match /master_backlog/{doc} {
      allow read, write: if isAuthenticated();
    }
    match /marketing_tasks/{doc} {
      allow read, write: if isAuthenticated();
    }

    // ── Intelligence Layer collections ────────────────────────────────────
    // Public read: Nouvia Studio reads these unauthenticated (client-side SDK).
    // Write is locked to authenticated users only (MCP server + admin).
    match /intelligence_clusters/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── Section 8 Delivery collections ───────────────────────────────────────
    match /engagements/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /delivery_tasks/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /delivery_costs/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /delivery_handoffs/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /defects/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /change_requests/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /delivery_actuals/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /intelligence_foundations/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /intelligence_rules/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /intelligence_patterns/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /intelligence_inject_queue/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /intelligence_harvest_requests/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /intelligence_usage_log/{doc} {
      allow read, write: if isAuthenticated();
    }

    // ── Operations Agent collections ─────────────────────────────────────────
    match /delivery_health/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /adoption_reports/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /client_communications/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

  }
}
