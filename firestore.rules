rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: single-user gate (INT-001 ADR-P02) ──────────────────────────
    function isBen() {
      return request.auth != null
          && request.auth.token.email == 'benmelchionno@nouvia.ai';
    }

    // ── Existing: per-user data store (getData / setData helpers) ───────────
    match /users/{userId}/{document=**} {
      allow read, write: if isBen();
    }

    // ── INT-001 WS1: IP Library ─────────────────────────────────────────────
    match /ip_library/{docId} {
      allow read, write: if isBen();
    }

    // ── INT-001 WS2: Dashboard collections ─────────────────────────────────
    match /okrs/{docId} {
      allow read, write: if isBen();
    }

    match /mrr_entries/{docId} {
      allow read, write: if isBen();
    }

    match /priority_queue/{docId} {
      allow read, write: if isBen();
    }

    match /tracker_events/{docId} {
      allow read, write: if isBen();
    }

    // ── INT-002 CEO Cockpit collections ─────────────────────────────────────
    match /goals/{docId} {
      allow read, write: if isBen();
    }

    match /client_backlog/{docId} {
      allow read, write: if isBen();
    }

    match /weekly_todos/{docId} {
      allow read, write: if isBen();
    }

    match /forecast_cache/{docId} {
      allow read, write: if isBen();
    }

    match /experiments/{docId} {
      allow read, write: if isBen();
    }

    match /trends/{docId} {
      allow read, write: if isBen();
    }

    match /decisions/{docId} {
      allow read, write: if isBen();
    }

  }
}
